#!/usr/bin/env bash
# nodegraph-analyzer-dotnet — invoke the published .NET analyzer DLL.
#
# Requires the .NET 9 runtime on PATH. The dist/ directory is created by
# `npm run build`, which runs `dotnet publish` against src/NodegraphAnalyzerDotnet.csproj.
set -e
# Resolve symlinks so `npm link` / `npm install -g` works — without
# this, the shim invoked through /opt/homebrew/bin/... walks up from
# the wrong directory and can't find dist/. Portable across BSD
# readlink (macOS default) and GNU readlink (Linux).
SRC="${BASH_SOURCE[0]}"
while [ -L "$SRC" ]; do
  TARGET="$(readlink "$SRC")"
  case "$TARGET" in
    /*) SRC="$TARGET" ;;
    *)  SRC="$(dirname "$SRC")/$TARGET" ;;
  esac
done
DIR="$( cd "$( dirname "$SRC" )/.." && pwd )"
DLL="$DIR/dist/NodegraphAnalyzerDotnet.dll"
if [ ! -f "$DLL" ]; then
  echo "nodegraph-analyzer-dotnet: $DLL not found." >&2
  echo "Run 'npm run build' inside the package, or reinstall after a clean publish." >&2
  exit 1
fi
exec dotnet "$DLL" "$@"
